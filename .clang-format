BasedOnStyle: Google
ColumnLimit: 100
IndentWidth: 2
ContinuationIndentWidth: 4
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<cuda'
    Priority: 2
  - Regex: '^<'
    Priority: 1
  # Project headers
  - Regex: '^"corelog/'
    Priority: 3
  - Regex: '.*'
    Priority: 4
