BasedOnStyle: Google
ColumnLimit: 100
IndentWidth: 2
ContinuationIndentWidth: 4
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<cuda'
    Priority: 2
  - Regex: '^<'
    Priority: 1
  # Project headers: replace 'yourproject' with the top-level include namespace
  # used in your project (e.g. '^"foo/' for #include "foo/bar.h").
  - Regex: '^"yourproject/'
    Priority: 3
  - Regex: '.*'
    Priority: 4
